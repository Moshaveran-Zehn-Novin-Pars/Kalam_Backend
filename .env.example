# ============================================
# 🥬 KALAM BACKEND - Environment Variables
# ============================================
# Copy this file to .env and fill in the actual values
# Never commit .env to version control!

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_URL=http://localhost:3000

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://kalam:kalam_dev@localhost:5432/kalam_dev

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# JWT Authentication
# ============================================
# IMPORTANT: Use a strong random string (min 32 chars) in production
JWT_SECRET=change-me-to-a-strong-random-string-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ============================================
# OTP Configuration
# ============================================
OTP_LENGTH=6
OTP_EXPIRES_SECONDS=120
OTP_MAX_ATTEMPTS=5

# ============================================
# SMS Provider (Kavenegar)
# ============================================
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=

# ============================================
# Payment Gateway (Zarinpal)
# ============================================
ZARINPAL_MERCHANT_ID=
ZARINPAL_CALLBACK_URL=http://localhost:3000/api/v1/payments/callback

# ============================================
# Object Storage (MinIO / S3)
# ============================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kalam-dev
S3_REGION=us-east-1
S3_USE_SSL=false

# ============================================
# AI Service (Python FastAPI)
# ============================================
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=

# ============================================
# Commission & Tax
# ============================================
DEFAULT_COMMISSION_RATE=0.06
TAX_RATE=0.09

# ============================================
# Maps (Neshan)
# ============================================
NESHAN_API_KEY=

# ============================================
# Monitoring
# ============================================
SENTRY_DSN=
LOG_LEVEL=debug

# ============================================
# Rate Limiting
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100