            "method": "PATCH",
            "url": "{{baseUrl}}/admin/products/:id/approve",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    }
  ]
}