              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Wallet Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/payments/wallet/transactions?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["payments", "wallet", "transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/initiate",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORDER_ID_HERE\",\n  \"method\": \"ONLINE_GATEWAY\",\n  \"gateway\": \"ZARINPAL\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🚚 Deliveries",
      "item": [
        {
          "name": "Get My Deliveries (Driver)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/deliveries/my",
            "header": [
